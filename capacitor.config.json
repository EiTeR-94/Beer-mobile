{
  "appId": "fr.eiter.plexibeer",
  "appName": "Plexi Beer",
  "webDir": "www",
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#0f1419",
    "allowsLinkPreview": false,
    "scrollEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 1500,
      "backgroundColor": "#0f1419",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f1419"
    }
  }
}