# Build IPA développement — compte Apple ID GRATUIT (AltStore)

opt_out_usage
default_platform(:ios)

def device_udid
  ENV["IOS_DEVICE_UDID"].to_s.strip.gsub(/\s+/, "")
end

def signing_team_id
  explicit = ENV["APPLE_TEAM_ID"].to_s.strip
  return explicit unless explicit.empty?

  UI.message("APPLE_TEAM_ID absent — détection automatique sur Mac GitHub…")

  Spaceship::Portal.login(
    ENV.fetch("APPLE_ID"),
    ENV.fetch("FASTLANE_PASSWORD")
  )

  teams = Spaceship::Portal.client.teams
  UI.user_error!("Aucune équipe Apple — vérifie APPLE_ID + mot de passe pour app") if teams.nil? || teams.empty?

  personal = teams.find { |t| t["type"].to_s == "Individual" }
  team = personal || teams.first
  tid = team["teamId"]

  UI.success("Team ID auto-détecté : #{tid} (#{team['name']})")
  UI.important("Tu peux ajouter ce Team ID en secret GitHub APPLE_TEAM_ID pour accélérer les prochains builds.")

  tid
rescue StandardError => e
  UI.user_error!(
    "Impossible de détecter le Team ID : #{e.message}\n\n" \
    "Plan B : installe 3uTools (3u.com), branche l'iPhone,\n" \
    "onglet Provisioning Profiles → copie le Team ID (10 caractères)\n" \
    "→ secret GitHub APPLE_TEAM_ID"
  )
end

platform :ios do
  desc "IPA AltStore — signature automatique Xcode (gratuit)"
  lane :build_ipa do
    udid = device_udid
    UI.user_error!("Secret GitHub IOS_DEVICE_UDID manquant ou invalide") if udid.length < 20

    setup_ci(force: true)

    team = signing_team_id
    UI.message("Team ID utilisé : #{team}")

    update_code_signing_settings(
      use_automatic_signing: true,
      path: "ios/App/App.xcodeproj",
      targets: ["App"],
      bundle_identifier: "fr.eiter.plexibeer",
      code_sign_identity: "Apple Development",
      team_id: team
    )

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "development",
      output_directory: "build",
      output_name: "PlexiBeer",
      clean: true,
      skip_package_ipa: false,
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{team}",
      export_xcargs: "-allowProvisioningUpdates"
    )
  end
end