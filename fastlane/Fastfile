# IPA non signée → AltStore / AltServer re-signe sur ton PC Windows (gratuit)

opt_out_usage
default_platform(:ios)

platform :ios do
  desc "Build IPA non signée pour AltStore"
  lane :build_ipa do
    setup_ci(force: true)

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/App/App.xcodeproj",
      targets: ["App"],
      bundle_identifier: "fr.eiter.plexibeer",
      code_sign_identity: "",
      team_id: ""
    )

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "development",
      output_directory: "build",
      output_name: "PlexiBeer",
      clean: true,
      skip_codesigning: true,
      skip_package_ipa: false,
      xcargs: "CODE_SIGN_IDENTITY='-' CODE_SIGNING_ALLOWED=NO CODE_SIGNING_REQUIRED=NO"
    )

    ipa = Dir["build/*.ipa"].first
    UI.user_error!("IPA non générée") unless ipa

    UI.success("IPA non signée : #{ipa}")
    UI.success("AltStore la re-signera avec ton Apple ID à l'installation.")
  end
end