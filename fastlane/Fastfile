# Build IPA développement — compte Apple ID GRATUIT (AltStore)
# Pas de portail developer.apple.com (souvent « Access Unavailable » sans les 99 €).

opt_out_usage
default_platform(:ios)

def device_udid
  ENV["IOS_DEVICE_UDID"].to_s.strip.gsub(/\s+/, "")
end

def signing_team_id
  ENV["APPLE_TEAM_ID"].to_s.strip
end

platform :ios do
  desc "IPA AltStore — signature automatique Xcode (gratuit)"
  lane :build_ipa do
    udid = device_udid
    UI.user_error!("Secret GitHub IOS_DEVICE_UDID manquant ou invalide") if udid.length < 20

    setup_ci(force: true)

    team = signing_team_id
    if team.empty?
      UI.important("APPLE_TEAM_ID absent — Xcode utilisera la Personal Team de #{ENV.fetch('APPLE_ID', 'ton Apple ID')}")
    else
      UI.message("Team ID : #{team}")
    end

    signing = {
      use_automatic_signing: true,
      path: "ios/App/App.xcodeproj",
      targets: ["App"],
      bundle_identifier: "fr.eiter.plexibeer",
      code_sign_identity: "Apple Development"
    }
    signing[:team_id] = team unless team.empty?

    update_code_signing_settings(signing)

    xcargs = "-allowProvisioningUpdates"
    xcargs += " DEVELOPMENT_TEAM=#{team}" unless team.empty?

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "development",
      output_directory: "build",
      output_name: "PlexiBeer",
      clean: true,
      skip_package_ipa: false,
      xcargs: xcargs,
      export_xcargs: "-allowProvisioningUpdates"
    )
  end
end