# Build IPA développement (compte Apple ID gratuit → AltStore)

opt_out_usage
default_platform(:ios)

def apple_team_id
  explicit = ENV["APPLE_TEAM_ID"].to_s.strip
  return explicit unless explicit.empty?

  UI.message("APPLE_TEAM_ID absent — détection via ton Apple ID…")
  Spaceship::Portal.login(
    ENV.fetch("APPLE_ID"),
    ENV.fetch("FASTLANE_PASSWORD")
  )
  teams = Spaceship::Portal.client.teams
  UI.user_error!("Aucune équipe Apple — accepte les conditions sur developer.apple.com") if teams.nil? || teams.empty?

  personal = teams.find { |t| t["type"].to_s == "Individual" }
  team = personal || teams.first
  UI.success("Team ID détecté : #{team['teamId']} (#{team['name']})")
  team["teamId"]
end

def device_udid
  ENV["IOS_DEVICE_UDID"].to_s.strip.gsub(/\s+/, "")
end

platform :ios do
  desc "Affiche le Team ID (debug)"
  lane :show_team_id do
    UI.success("Team ID = #{apple_team_id}")
  end

  desc "Certificats + profil pour l'iPhone du testeur"
  lane :prepare_signing do
    setup_ci(force: true)

    team = apple_team_id
    apple_id = ENV.fetch("APPLE_ID")

    begin
      produce(
        app_identifier: "fr.eiter.plexibeer",
        app_name: "Plexi Beer",
        skip_itc: true,
        username: apple_id,
        team_id: team
      )
    rescue StandardError => e
      UI.message("produce ignoré : #{e.message}")
    end

    udid = device_udid
    UI.user_error!("IOS_DEVICE_UDID vide ou invalide") if udid.length < 20

    register_devices(
      devices: { "Plexi iPhone" => udid },
      team_id: team,
      username: apple_id
    )

    cert(
      development: true,
      username: apple_id,
      team_id: team,
      force: false
    )

    sigh(
      development: true,
      app_identifier: "fr.eiter.plexibeer",
      username: apple_id,
      team_id: team,
      force: true,
      include_all_certificates: true
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: team,
      code_sign_identity: "Apple Development",
      path: "ios/App/App.xcodeproj",
      targets: ["App"],
      profile_name: lane_context[SharedValues::SIGH_NAME],
      bundle_identifier: "fr.eiter.plexibeer"
    )
  end

  desc "Archive + export IPA pour AltStore"
  lane :build_ipa do
    prepare_signing

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "development",
      output_directory: "build",
      output_name: "PlexiBeer",
      clean: true,
      skip_package_ipa: false,
      xcargs: "-allowProvisioningUpdates"
    )
  end
end